# Supabase (standalone project for the SME Library)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — used by the generate_sme tool
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to claude-opus-4-8
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: shown on the landing page connect snippet
# NEXT_PUBLIC_BASE_URL=https://sme-library.vercel.app

# Local stdio transport only (bin/stdio.js)
# SME_API_KEY=sme_live_...
